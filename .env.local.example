# Local development environment variables template
# Copy this to .env.local and fill in your actual values

# Neon PostgreSQL connection string
# Get this from: https://console.neon.tech/
DATABASE_URL=postgresql://user:password@ep-xxxx.region.azure.neon.tech/dbname?sslmode=require&channel_binding=require

# Clerk API Keys (Optional for local dev)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_publishable_key
CLERK_SECRET_KEY=your_secret_key

# Anthropic API Key (for Claude integration)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Claude API Key (for fitness-api)
CLAUDE_API_KEY=your_claude_api_key
